{
  "buildCommand": "npm run build:deploy",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/naver/:path*",
      "destination": "https://openapi.naver.com/:path*"
    },
    {
      "source": "/api/kakao-oauth/:path*",
      "destination": "https://kauth.kakao.com/:path*"
    },
    {
      "source": "/api/kakao-api/:path*",
      "destination": "https://kapi.kakao.com/:path*"
    }
  ]
}
